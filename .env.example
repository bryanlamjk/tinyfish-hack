# Copy this file to .env and fill in your own keys before running locally.

# Required for Tinyfish searches.
TINYFISH_API_KEY=your_tinyfish_api_key_here

# Optional for Gemini provider discovery. Either variable name works.
GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=your_gemini_api_key_here
