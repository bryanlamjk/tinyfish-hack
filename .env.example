# Copy this file to .env and fill in your own keys before running locally.

# Required for Tinyfish searches.
TINYFISH_API_KEY=your_tinyfish_api_key_here

# Optional for Gemini provider discovery. Either variable name works.
GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=your_gemini_api_key_here

# Optional for LangSmith tracing. Tracing is enabled automatically when this key is set,
# unless you explicitly set LANGSMITH_TRACING=false.
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGSMITH_PROJECT=tinyfish-travel-deals-agent
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_WORKSPACE_ID=your_workspace_id_here
